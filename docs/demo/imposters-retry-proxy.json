{
  "imposters": [
    {
      "port": 4560,
      "protocol": "http",
      "name": "Retry Proxy Simulation",
      "recordRequests": true,
      "_rift": {
        "flowState": {
          "backend": "inmemory",
          "ttlSeconds": 300,
          "flowIdSource": "header:X-Flow-Id"
        }
      },
      "stubs": [
        {
          "name": "Retry Simulation - Fail first 2 requests, pass 3rd to upstream",
          "predicates": [
            {
              "equals": {
                "path": "/api/resource"
              }
            }
          ],
          "responses": [
            {
              "_rift": {
                "script": {
                  "engine": "rhai",
                  "code": "fn respond(ctx) { let attempts = ctx.state.incr(\"attempts\"); if attempts <= 2 { http(503, #{ error: \"Service temporarily unavailable\", attempt: attempts, message: \"Retry after a moment\" }).header(\"Retry-After\", \"1\").header(\"X-Attempt\", `${attempts}`) } else { pass() } }"
                }
              },
              "_behaviors": {
                "proxy": {
                  "to": "http://upstream:8080",
                  "mode": "proxyAlways"
                }
              }
            }
          ]
        },
        {
          "name": "Reset attempts counter",
          "predicates": [
            {
              "equals": {
                "method": "DELETE",
                "path": "/api/reset"
              }
            }
          ],
          "responses": [
            {
              "_rift": {
                "script": {
                  "engine": "rhai",
                  "code": "fn respond(ctx) { ctx.state.delete(\"attempts\"); http(200, #{ message: `Counter reset for flow: ${ctx.flowId}` }) }"
                }
              }
            }
          ]
        },
        {
          "name": "Get current attempt count",
          "predicates": [
            {
              "equals": {
                "method": "GET",
                "path": "/api/attempts"
              }
            }
          ],
          "responses": [
            {
              "_rift": {
                "script": {
                  "engine": "rhai",
                  "code": "fn respond(ctx) { let attempts = ctx.state.get_or(\"attempts\", 0); http(200, #{ flow_id: ctx.flowId, attempts: attempts }) }"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
