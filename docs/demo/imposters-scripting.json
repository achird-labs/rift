{
  "imposters": [
    {
      "port": 4550,
      "protocol": "http",
      "name": "Rift Scripting Demo - Flow State",
      "recordRequests": true,
      "_rift": {
        "flowState": {
          "backend": "inmemory",
          "ttlSeconds": 600
        }
      },
      "stubs": [
        {
          "name": "Counter - Increment",
          "predicates": [
            { "equals": { "method": "POST", "path": "/api/counter/increment" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { let counter = ctx.state.incr(\"counter\"); http(200, #{ counter: counter }) }"
              }
            }
          }]
        },
        {
          "name": "Counter - Get",
          "predicates": [
            { "equals": { "method": "GET", "path": "/api/counter" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { let counter = ctx.state.get_or(\"counter\", 0); http(200, #{ counter: counter }) }"
              }
            }
          }]
        },
        {
          "name": "Counter - Reset",
          "predicates": [
            { "equals": { "method": "DELETE", "path": "/api/counter" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { ctx.state.delete(\"counter\"); http(200, #{ message: \"Counter reset\" }) }"
              }
            }
          }]
        },
        {
          "name": "Rate Limiter - Check",
          "predicates": [
            { "equals": { "path": "/api/rate-limited" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { let count = ctx.state.incr(\"requests\"); if count > 5 { http(429, #{ error: \"Rate limit exceeded\", requests: count, limit: 5 }).header(\"Retry-After\", \"60\") } else { let remaining = 5 - count; http(200, #{ message: \"OK\", requests: count, remaining: remaining }).header(\"X-RateLimit-Remaining\", `${remaining}`) } }"
              }
            }
          }]
        },
        {
          "name": "Rate Limiter - Reset",
          "predicates": [
            { "equals": { "method": "DELETE", "path": "/api/rate-limited/reset" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { ctx.state.delete(\"requests\"); http(200, #{ message: \"Rate limit reset\" }) }"
              }
            }
          }]
        },
        {
          "name": "Request Echo",
          "predicates": [
            { "equals": { "method": "POST", "path": "/api/echo" } }
          ],
          "responses": [{
            "_rift": {
              "script": {
                "engine": "rhai",
                "code": "fn respond(ctx) { let count = ctx.state.incr(\"count\"); http(200, #{ method: ctx.request.method, path: ctx.request.path, echoCount: count }) }"
              }
            }
          }]
        }
      ]
    }
  ]
}
